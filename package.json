{
  "name": "rs-toolkit-ultimate-nexus",
  "version": "3.1.0",
  "description": "OMNIPOTENT SOVEREIGN NEXUS - Elite Security Toolkit with Advanced UI/UX Framework by RAJSARASWATI JATAV (RS) - T3rmuxk1ng",
  "author": "RAJSARASWATI JATAV (RS) - T3rmuxk1ng",
  "license": "OMNIPOTENT-SOVEREIGN-NEXUS",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbo --port 3000",
    "dev:https": "next dev --turbo --port 3000 --experimental-https",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:standalone": "next build && cp -r .next/standalone ./dist && cp -r .next/static ./dist/.next/static",
    "start": "next start --port 3000",
    "start:prod": "NODE_ENV=production node .next/standalone/server.js",
    "lint": "next lint --fix --dir src --dir app --dir components --dir lib",
    "lint:strict": "next lint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md,mdx}\"",
    "clean": "rm -rf .next node_modules/.cache dist coverage .turbo",
    "clean:all": "rm -rf .next node_modules dist coverage .turbo && npm install",
    "prepare": "husky",
    "precommit": "lint-staged",
    "release": "standard-version",
    "release:major": "standard-version --release-as major",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "bump:version": "npm version patch --no-git-tag-version",
    "deps:check": "npm outdated",
    "deps:update": "npm update",
    "deps:audit": "npm audit --audit-level=moderate",
    "deps:audit:fix": "npm audit fix",
    "bundle:analyze": "ANALYZE=true next build && open .next/analyze/client.html",
    "bundle:size": "next build && du -sh .next",
    "export": "next build && next export -o ./out",
    "docker:build": "docker build -t rs-toolkit:latest .",
    "docker:run": "docker run -p 3000:3000 rs-toolkit:latest",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "cap:init": "npx cap init 'RS Toolkit' 'com.t3rmuxk1ng.rstoolkit'",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "android:build": "cd android && ./gradlew assembleRelease",
    "android:debug": "cd android && ./gradlew assembleDebug",
    "ios:build": "cd ios && xcodebuild -workspace App.xcworkspace -scheme App -configuration Release",
    "pwa:generate": "npx pwa-asset-generator public/logo.svg public/icons",
    "lighthouse": "lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html",
    "security:scan": "npm audit --json | npm-audit-html --output security-report.html",
    "performance": "next build && lighthouse http://localhost:3000 --only-categories=performance --output json",
    "sitemap": "next-sitemap",
    "robots": "next-robotstxt",
    "docs:generate": "typedoc --out docs src",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "codegen": "graphql-codegen --config codegen.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "env:check": "npx check-env",
    "postinstall": "prisma generate || true",
    "setup": "npm install && npm run prisma:generate && npm run build"
  },
